{
  "version": 2,
  "builds": [
    {
      "src": "frontend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src":  "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}